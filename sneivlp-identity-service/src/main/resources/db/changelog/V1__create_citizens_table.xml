<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="2026-06-23-create-citizens" author="saikumar">

        <createTable tableName="citizens">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             nullable="false"/>
            </column>

            <column name="citizen_id" type="VARCHAR(50)">
                <constraints nullable="false"
                             unique="true"/>
            </column>

            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="middle_name" type="VARCHAR(100)"/>

            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="gender" type="VARCHAR(20)"/>

            <column name="date_of_birth" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="mobile_number" type="VARCHAR(20)"/>

            <column name="email" type="VARCHAR(255)"/>

            <column name="aadhaar_reference" type="VARCHAR(50)"/>

            <column name="status" type="VARCHAR(30)"/>

            <column name="verification_status" type="VARCHAR(30)"/>

            <column name="created_date" type="TIMESTAMP"/>

            <column name="updated_date" type="TIMESTAMP"/>

            <column name="created_by" type="VARCHAR(100)"/>

            <column name="updated_by" type="VARCHAR(100)"/>

            <column name="is_active" type="BOOLEAN"/>

            <column name="is_deleted" type="BOOLEAN"/>

        </createTable>

        <addUniqueConstraint
                tableName="citizens"
                columnNames="mobile_number"
                constraintName="uq_citizens_mobile"/>

        <addUniqueConstraint
                tableName="citizens"
                columnNames="email"
                constraintName="uq_citizens_email"/>

        <addUniqueConstraint
                tableName="citizens"
                columnNames="aadhaar_reference"
                constraintName="uq_citizens_aadhaar"/>

        <createIndex
                tableName="citizens"
                indexName="idx_citizens_aadhaar">

            <column name="aadhaar_reference"/>

        </createIndex>

    </changeSet>

</databaseChangeLog>